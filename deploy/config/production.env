# Necitlivé nastavení nasazení JEF.
#
# Tenhle soubor je VERZOVANÝ (commitnutý) — stejně jako u referenčního projektu jsme
# bezpečnost zjednodušili (školní projekt): jediné skutečné tajemství je SSH klíč
# v GitHub secrets (SSH_PRIVATE_KEY), kterým se Actions přihlásí na server.
#
# Soubor slouží dvěma věcem zároveň:
#   1) interpolaci proměnných v docker-compose.yml (např. ${APP_HOST} v traefik štítcích)
#   2) jako env_file kontejneru `web` (Django čte DJANGO_* z prostředí)

# --- ingress přes traefik na serveru ---
# !!! DOPLŇ AŽ DOSTANEŠ PŘÍSTUPY !!!
# Doména, na které aplikace poběží. Traefik (na sdílené síti `proxy`) podle ní
# směruje provoz na frontend nginx a přes Let's Encrypt vystaví HTTPS certifikát.
# (Vzor učitele byl vch.gawt.dtcloud.cz — tvoji subdoménu dostaneš s přístupy.)
APP_HOST=sk.gawt.dtcloud.cz
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# --- Django runtime ---
DJANGO_DEBUG=0
# Produkční SECRET_KEY. Vygeneruj si vlastní:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=+e@+qjitnj*e19h@w!%bvbinf28o*0y3*hqsfgfa!*13c%-5&!
# !!! Doplň svoji doménu (stejnou jako APP_HOST). `web` je potřeba kvůli internímu volání. !!!
DJANGO_ALLOWED_HOSTS=sk.gawt.dtcloud.cz,localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=https://sk.gawt.dtcloud.cz

# Vue SPA je hlavní frontend a běží na rootu `/` (servíruje ji nginx).
VUE_FRONTEND_URL=/

# Cesty k datům uvnitř kontejneru (odpovídají volume v docker-compose.yml).
DJANGO_DB_PATH=/data/db/db.sqlite3
DJANGO_STATIC_ROOT=/data/static
DJANGO_MEDIA_ROOT=/data/media
